# Clé secrète Flask — générer avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Base de données PostgreSQL
DATABASE_URL=postgresql://releves_user:motdepasse@localhost:5432/releves_db

# Dossier de stockage des fichiers uploadés (hors web root)
UPLOAD_FOLDER=/var/app-data/releves

# Taille max upload en Mo
MAX_UPLOAD_SIZE_MB=10

# Durée de session en minutes
SESSION_TIMEOUT_MINUTES=30

# Mode Flask
FLASK_ENV=development
FLASK_DEBUG=1
